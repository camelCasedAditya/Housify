DJANGO_SECRET_KEY=dev-insecure-change-me
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
# Leave blank to use Anthropic's API directly, or set to a compatible proxy
# (e.g. https://api.vibetoken.lol) which mirrors the Anthropic Messages API.
ANTHROPIC_BASE_URL=
OLLAMA_CLOUD_HOST=https://ollama.com
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL=gpt-oss:120b-cloud
LLM_MAX_USD_PER_GEN=0.10
# Docker Compose: use service names (`redis`). For bare-metal dev, use `localhost`.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
